{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Process",
      "type": "coreclr",
      "request": "attach"
    },
    {
      "name": "Launch CyberAwareBot (macOS via dotnet)",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": ["${workspaceFolder}/CyberAwareBot/bin/Debug/net8.0/CyberAwareBot.dll"],
      "cwd": "${workspaceFolder}/CyberAwareBot",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "preLaunchTask": "build"
    }
  ]
}
