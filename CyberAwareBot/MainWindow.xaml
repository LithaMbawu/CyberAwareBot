<?xml version="1.0" encoding="UTF-8"?>
<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" Height="700" Width="900"
        Background="#2E3440" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ChatTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderBrush" Value="#5E81AC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#5E81AC"/>
            <Setter Property="Foreground" Value="#ECEFF4"/>
            <Setter Property="BorderBrush" Value="#81A1C1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with app title and ASCII art -->
        <Border Grid.Row="0" Background="#434C5E" CornerRadius="5" Margin="10" Padding="12">
            <StackPanel>
                <TextBlock Text="Cybersecurity Awareness Chatbot"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI Semibold"
                           FontSize="20"
                           Foreground="#ECEFF4"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Get friendly, expert security guidance in a natural chat experience."
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#D8DEE9"
                           Margin="0,0,0,12"/>
                <TextBlock x:Name="AsciiArtText"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"
                           FontSize="14"
                           Foreground="#88C0D0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Chat History -->
        <Border Grid.Row="1" Background="#3B4252" CornerRadius="5" Margin="10">
            <ScrollViewer x:Name="ChatScrollViewer" Margin="10">
                <TextBlock x:Name="ChatHistoryTextBlock" Style="{StaticResource ChatTextStyle}"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#434C5E" CornerRadius="5" Margin="10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UserInputTextBox" Grid.Column="0" Margin="0,0,10,0"
                         Style="{StaticResource InputStyle}" KeyDown="UserInputTextBox_KeyDown"/>
                <Button x:Name="SendButton" Grid.Column="1" Content="Send"
                        Style="{StaticResource ButtonStyle}" Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

